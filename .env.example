# --- Production (required for public deployment) ---
PUBLIC_API_URL=https://api.your-domain.com
CORS_ORIGINS=https://agents.your-domain.com,https://workers.your-domain.com
WORKER_APP_URL=https://workers.your-domain.com
YAAS_API_URL=https://api.your-domain.com
R2_PUBLIC_URL=https://proofs.your-cdn.com

# --- Infrastructure ---
DATABASE_URL=postgresql://user:pass@your-neon-host/yaas
REDIS_URL=redis://your-upstash-host:6379
JWT_SECRET=change-me-in-production
PORT=3000

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# --- Cloudflare R2 (proof storage) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=yaas-proofs

# --- MCP client (set in Claude Desktop / agent runtime) ---
YAAS_API_KEY=sk_yaas_...

# --- Local development overrides (see .env.local.example) ---
# SKIP_STRIPE=true
# SKIP_QUEUES=true
